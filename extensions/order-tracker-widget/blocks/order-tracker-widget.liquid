<div
  id="shiprocket-order-tracker-{{ block.id }}"
  class="shiprocket-order-tracker-root"
  data-heading="{{ block.settings.heading | escape }}"
  data-description="{{ block.settings.description | escape }}"
  data-launcher-label="{{ block.settings.launcher_label | escape }}"
  data-welcome-message="{{ block.settings.welcome_message | escape }}"
  data-placeholder="{{ block.settings.placeholder | escape }}"
  data-button-label="{{ block.settings.button_label | escape }}"
  data-proxy-path="{{ block.settings.proxy_path | escape }}"
  data-direct-api-url="{{ block.settings.direct_api_url | escape }}"
  data-shop-domain="{{ request.host | default: shop.domain | default: shop.permanent_domain | escape }}"
  {{ block.shopify_attributes }}
></div>

{% schema %}
{
  "name": "Order Assistant Chatbot",
  "target": "body",
  "stylesheet": "order-tracker-widget.css",
  "javascript": "order-tracker-widget.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Store assistant"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Ask about products, collections, prices, availability, shipping, returns, or enter AWB / order ID for live tracking."
    },
    {
      "type": "text",
      "id": "launcher_label",
      "label": "Launcher label",
      "default": "Chat with us"
    },
    {
      "type": "textarea",
      "id": "welcome_message",
      "label": "Welcome message",
      "default": "Ask about products, collections, prices, availability, shipping, returns, or send your AWB / order ID for live tracking."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Type message, AWB or order ID"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send"
    },
    {
      "type": "text",
      "id": "proxy_path",
      "label": "Chat proxy path",
      "default": "/apps/track-order/chat"
    },
    {
      "type": "text",
      "id": "direct_api_url",
      "label": "Direct API URL",
      "default": "https://shopify-store-assistant-app.vercel.app/api/chatbot"
    }
  ]
}
{% endschema %}
